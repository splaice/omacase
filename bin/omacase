#!/bin/bash
# omacase — single command to install, configure, theme, and manage an
# opinionated tiling macOS. Subcommands live in lib/*.sh.
set -euo pipefail

# Resolve the repo root regardless of how we were invoked (symlink-safe).
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
export OMACASE_ROOT="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"

source "$OMACASE_ROOT/lib/common.sh"

usage() {
  cat <<'EOF'
Omacase — opinionated tiling macOS, managed from one command

usage: omacase <command> [args]

  install            Full idempotent setup (re-runnable)
  update             git pull + brew bundle + re-apply dotfiles & defaults
  theme [name]       Apply a theme everywhere (no name = list/pick)
  webapp [name]      Open an Omarchy web app (no name = list); for Spotlight Shortcuts
  appearance [...]   Toggle/set macOS Light/Dark (toggle|dark|light)
  launchers [...]    Generate Spotlight .app launchers for web apps (build|remove)
  wm <aerospace|yabai>   Switch window-manager profile
  grid [1-9]         Toggle an AeroSpace workspace (default: focused) into a 2x2 grid
  workspace <1-9>    Switch to an AeroSpace workspace (alias: ws)
  terminal [cmd...]  Open a new Ghostty window in the running instance, optionally running cmd (alias: term)
  btop               Toggle a centered, chromeless btop popup (SketchyBar CPU/mem click)
  caffeinate [...]   Toggle a stay-awake power assertion (toggle|on|off|status)
  doctor             Check permissions, SIP state, and missing grants
  backup [label]     Snapshot current dotfiles & macOS defaults
  restore [id]       Roll back to a snapshot (--list to see them)
  config             Open the config directory
  menu               Interactive TUI (wrap in a Shortcut to launch from Spotlight)
  version            Print version
  uninstall          Remove omacase-managed config (keeps your apps)

Run `omacase doctor` after install to grant Accessibility permissions.
EOF
}

cmd="${1:-menu}"; shift || true
case "$cmd" in
  install)        source "$OMACASE_ROOT/lib/install.sh";  omacase_install "$@" ;;
  update)         source "$OMACASE_ROOT/lib/update.sh";   omacase_update  "$@" ;;
  theme)          source "$OMACASE_ROOT/lib/theme.sh";    omacase_theme   "$@" ;;
  webapp)         source "$OMACASE_ROOT/lib/actions.sh";  omacase_webapp     "$@" ;;
  appearance)     source "$OMACASE_ROOT/lib/actions.sh";  omacase_appearance "$@" ;;
  launchers)      source "$OMACASE_ROOT/lib/actions.sh";  omacase_launchers  "$@" ;;
  caffeinate|caffeine) source "$OMACASE_ROOT/lib/actions.sh"; omacase_caffeinate "$@" ;;
  wm)             source "$OMACASE_ROOT/lib/wm.sh";       omacase_wm      "$@" ;;
  grid)           source "$OMACASE_ROOT/lib/wm.sh";       omacase_grid    "$@" ;;   # optional workspace arg
  workspace|ws)   source "$OMACASE_ROOT/lib/wm.sh";       omacase_workspace "$@" ;;
  terminal|term)  source "$OMACASE_ROOT/lib/wm.sh";       omacase_terminal  "$@" ;;
  btop)           source "$OMACASE_ROOT/lib/wm.sh";       omacase_btop      "$@" ;;
  doctor)         source "$OMACASE_ROOT/lib/doctor.sh";   omacase_doctor  "$@" ;;
  backup)         source "$OMACASE_ROOT/lib/backup.sh";   omacase_backup  "$@" ;;
  restore)        source "$OMACASE_ROOT/lib/backup.sh";   omacase_restore "$@" ;;
  menu)           source "$OMACASE_ROOT/lib/menu.sh";     omacase_menu    "$@" ;;
  config)         exec "${EDITOR:-open}" "$OMACASE_ROOT/home" ;;
  version|-v|--version) cat "$OMACASE_ROOT/VERSION" ;;
  uninstall)      source "$OMACASE_ROOT/lib/install.sh";  omacase_uninstall "$@" ;;
  help|-h|--help) usage ;;
  *) error "unknown command: $cmd"; echo; usage; exit 1 ;;
esac
