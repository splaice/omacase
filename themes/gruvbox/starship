# Gruvbox — Starship prompt (used as $STARSHIP_CONFIG via theme.toml).
"$schema" = 'https://starship.rs/config-schema.json'
add_newline = true
palette = 'gruvbox'
format = '$directory$git_branch$git_status$nodejs$python$character'

[palettes.gruvbox]
blue = '#7daea3'
green = '#a9b665'
red = '#ea6962'
mauve = '#d3869b'
yellow = '#d8a657'

[directory]
style = 'bold blue'
truncation_length = 3
truncate_to_repo = true

[git_branch]
symbol = ' '
style = 'bold mauve'

[git_status]
style = 'bold red'

[nodejs]
symbol = ' '
style = 'green'

[python]
symbol = ' '
style = 'yellow'

[character]
success_symbol = '[➜](bold green)'
error_symbol = '[➜](bold red)'
