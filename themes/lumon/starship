# Lumon — Starship prompt (used as $STARSHIP_CONFIG via theme.toml).
"$schema" = 'https://starship.rs/config-schema.json'
add_newline = true
palette = 'lumon'
format = '$directory$git_branch$git_status$nodejs$python$character'

[palettes.lumon]
blue = '#6fb8e3'
green = '#5e95bc'
red = '#4d86b0'
mauve = '#8bc9eb'
yellow = '#6fa4c9'

[directory]
style = 'bold blue'
truncation_length = 3
truncate_to_repo = true

[git_branch]
symbol = ' '
style = 'bold mauve'

[git_status]
style = 'bold red'

[nodejs]
symbol = ' '
style = 'green'

[python]
symbol = ' '
style = 'yellow'

[character]
success_symbol = '[➜](bold green)'
error_symbol = '[➜](bold red)'
