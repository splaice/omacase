# Hackerman — Starship prompt (used as $STARSHIP_CONFIG via theme.toml).
"$schema" = 'https://starship.rs/config-schema.json'
add_newline = true
palette = 'hackerman'
format = '$directory$git_branch$git_status$nodejs$python$character'

[palettes.hackerman]
blue = '#829dd4'
green = '#4fe88f'
red = '#50f872'
mauve = '#86a7df'
yellow = '#50f7d4'

[directory]
style = 'bold blue'
truncation_length = 3
truncate_to_repo = true

[git_branch]
symbol = ' '
style = 'bold mauve'

[git_status]
style = 'bold red'

[nodejs]
symbol = ' '
style = 'green'

[python]
symbol = ' '
style = 'yellow'

[character]
success_symbol = '[➜](bold green)'
error_symbol = '[➜](bold red)'
