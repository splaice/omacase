#!/bin/bash
# omacase SketchyBar — AeroSpace workspaces with app icons + stay-awake toggle.
# Each workspace item shows its number plus an icon for every app open in it
# (chryoung's pure-shell AeroSpace plugin, FelixKratz/SketchyBar discussion #12,
# adapted to omacase's theme + inlined-helper style). Focus shows by color and
# an ACCENT outline. The strip sits on the right (reversed, space.N…space.1);
# the caffeine stay-awake toggle sits on the far left.
# Theme colors come from ~/.config/sketchybar/theme.sh (set by `omacase theme`).
source "$HOME/.config/sketchybar/theme.sh" 2>/dev/null || true
: "${BAR_COLOR:=0xff1e1e2e}" "${LABEL_COLOR:=0xffcdd6f4}" "${ACCENT:=0xff89b4fa}" "${MUTED:=0xff6c7086}"

# SketchyBar's daemon runs with a minimal PATH (no Homebrew), so bare `aerospace`
# isn't found in click/init scripts it spawns. Resolve an absolute path once and
# bake it into those commands.
AEROSPACE="$(command -v aerospace 2>/dev/null)"
[ -n "$AEROSPACE" ] || for p in /opt/homebrew/bin/aerospace /usr/local/bin/aerospace; do
  [ -x "$p" ] && AEROSPACE="$p" && break
done
AEROSPACE="${AEROSPACE:-aerospace}"

sketchybar --bar height=32 position=bottom padding_left=8 padding_right=8 color="$BAR_COLOR"
sketchybar --default label.color="$LABEL_COLOR" icon.color="$LABEL_COLOR" \
  label.font="JetBrainsMono Nerd Font:Bold:13.0" padding_left=4 padding_right=4

# The custom event must exist BEFORE any item subscribes to it, otherwise the
# --subscribe silently no-ops and items never receive workspace-change updates.
sketchybar --add event aerospace_workspace_change

# App-icon helper: get_app_icon maps an app name to a Nerd Font glyph, and
# update_icons paints a workspace's label with one glyph per open app. Resolves
# aerospace itself (daemon PATH lacks Homebrew). Material Design glyphs are
# emitted as \x UTF-8 bytes on purpose — macOS /bin/bash is 3.2, which leaves
# $'\u…' as a literal string; \x byte escapes it does expand. Add apps/icons by
# extending the case below (see the discussion's icons.sh for more glyphs).
cat > "$HOME/.config/sketchybar/spaces.sh" <<'SPACES'
#!/bin/bash
AERO="$(command -v aerospace 2>/dev/null)"
[ -n "$AERO" ] || for p in /opt/homebrew/bin/aerospace /usr/local/bin/aerospace; do
  [ -x "$p" ] && AERO="$p" && break
done
AERO="${AERO:-aerospace}"

ICON_WEB=$'\xf3\xb0\x87\xa7'       # browsers
ICON_DEV=$'\xf3\xb0\x85\xa8'       # editors / IDEs
ICON_TERM=$'\xf3\xb0\x86\x8d'      # terminals
ICON_FILE=$'\xf3\xb0\x89\x8b'      # Finder
ICON_CHAT=$'\xf3\xb0\x8d\xa9'      # chat
ICON_MUSIC=$'\xf3\xb0\x8e\x84'     # music
ICON_NOTE=$'\xf3\xb1\x9e\x8e'      # notes / docs
ICON_COG=$'\xf3\xb0\x92\x93'       # system settings / info
ICON_CHART=$'\xf3\xb1\x95\x8d'     # activity monitor
ICON_MAIL=$'\xf3\xb0\x87\xae'      # mail
ICON_CALENDAR=$'\xf3\xb0\x83\xad'  # calendar
ICON_PASSKEY=$'\xf3\xb0\xb7\xa1'   # 1Password
ICON_APP=$'\xf3\xb0\xa3\x86'       # fallback app
ICON_NONE=$'\xe2\x80\x94'          # em dash — empty workspace

get_app_icon() {
  case "$1" in
    "Arc"|"Safari"|"Google Chrome"|"Firefox"|"Brave Browser")  printf '%s' "$ICON_WEB" ;;
    "Code"|"Visual Studio Code"|"VSCodium"|"Xcode"|"Zed")       printf '%s' "$ICON_DEV" ;;
    "Ghostty"|"iTerm2"|"Terminal"|"Warp"|"Alacritty")          printf '%s' "$ICON_TERM" ;;
    "Finder")                                                   printf '%s' "$ICON_FILE" ;;
    "Discord"|"Slack"|"Telegram"|"Messages")                   printf '%s' "$ICON_CHAT" ;;
    "Spotify"|"Music")                                          printf '%s' "$ICON_MUSIC" ;;
    "Notes"|"TextEdit"|"Stickies"|"Microsoft Word")            printf '%s' "$ICON_NOTE" ;;
    "System Settings"|"System Information")                     printf '%s' "$ICON_COG" ;;
    "Activity Monitor")                                         printf '%s' "$ICON_CHART" ;;
    "Mail"|"Microsoft Outlook")                                 printf '%s' "$ICON_MAIL" ;;
    "Calendar")                                                 printf '%s' "$ICON_CALENDAR" ;;
    "1Password")                                                printf '%s' "$ICON_PASSKEY" ;;
    *)                                                          printf '%s' "$ICON_APP" ;;
  esac
}

update_icons() {
  local wid="$1" apps icon_line=""
  apps="$("$AERO" list-windows --workspace "$wid" --format '%{app-name}' 2>/dev/null | sort -u)"
  if [ -z "$apps" ]; then
    icon_line=" $ICON_NONE"
  else
    while IFS= read -r app; do
      [ -z "$app" ] && continue
      icon_line+="$(get_app_icon "$app")  "
    done <<< "$apps"
  fi
  sketchybar --animate tanh 10 --set "space.$wid" label="$icon_line"
}
SPACES
chmod +x "$HOME/.config/sketchybar/spaces.sh"

# Per-item script: highlight the focused workspace (color + ACCENT outline) and
# refresh its app icons. Runs on workspace changes (FOCUSED_WORKSPACE supplied
# by AeroSpace's trigger) and on window changes (FOCUSED_WORKSPACE absent, so
# fall back to asking AeroSpace).
cat > "$HOME/.config/sketchybar/space_handler.sh" <<'HANDLER'
#!/bin/bash
source "$HOME/.config/sketchybar/theme.sh" 2>/dev/null || true
: "${ACCENT:=0xff89b4fa}" "${MUTED:=0xff6c7086}"
source "$HOME/.config/sketchybar/spaces.sh"

WID="$1"
FOCUSED="$FOCUSED_WORKSPACE"
[ -n "$FOCUSED" ] || FOCUSED="$("$AERO" list-workspaces --focused 2>/dev/null)"

if [ "$WID" = "$FOCUSED" ]; then
  sketchybar --set "$NAME" icon.highlight=on label.highlight=on \
    background.border_color="$ACCENT" background.border_width=2
else
  sketchybar --set "$NAME" icon.highlight=off label.highlight=off \
    background.border_color=0x00000000 background.border_width=0
fi

update_icons "$WID"
HANDLER
chmod +x "$HOME/.config/sketchybar/space_handler.sh"

# One item per AeroSpace workspace, on the right. Transparent pill; the handler
# paints the ACCENT outline on the focused one. `order` is built ascending
# (space.1 … space.N); --reorder lays items out as the reverse of its list, so
# the strip reads high→low left-to-right (space.N … space.1, space.1 far right).
order=""
for wid in $("$AEROSPACE" list-workspaces --all 2>/dev/null | sort -n); do
  sketchybar --add item "space.$wid" right \
    --set "space.$wid" \
      icon="$wid" icon.color="$MUTED" icon.highlight_color="$ACCENT" \
      icon.padding_left=8 icon.padding_right=4 \
      label.color="$MUTED" label.highlight_color="$ACCENT" \
      label.font="JetBrainsMono Nerd Font:Regular:15.0" label.padding_right=8 \
      background.color=0x00000000 background.corner_radius=6 background.height=24 \
      background.border_width=0 background.border_color=0x00000000 \
      script="$HOME/.config/sketchybar/space_handler.sh $wid" \
      click_script="$AEROSPACE workspace $wid" \
    --subscribe "space.$wid" aerospace_workspace_change space_windows_change
  order="$order space.$wid"
done

# Caffeine / stay-awake toggle (replaces Taurine). Click holds a power
# assertion via the built-in `caffeinate` — no app needed. The assertion lives
# in its own process, so we track it by pidfile: state survives bar reloads,
# and a stale pid (e.g. after a reboot, when caffeinate is gone) reconciles
# back to "off". State shows by icon color alone — ACCENT when awake, MUTED off.
cat > "$HOME/.config/sketchybar/caffeine.sh" <<'CAFFEINE'
#!/bin/bash
source "$HOME/.config/sketchybar/theme.sh" 2>/dev/null || true
: "${ACCENT:=0xff89b4fa}" "${MUTED:=0xff6c7086}"
PIDFILE="$HOME/.config/sketchybar/caffeinate.pid"
CAFFEINATE=/usr/bin/caffeinate   # always present; /usr/bin is on the daemon PATH

awake() {   # succeeds only if the caffeinate we started is still alive
  local pid
  pid="$(cat "$PIDFILE" 2>/dev/null)" || return 1
  [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null
}

if [ "$1" = toggle ]; then
  if awake; then
    kill "$(cat "$PIDFILE")" 2>/dev/null
    rm -f "$PIDFILE"
  else
    # -d prevents display sleep, -i prevents system idle sleep; runs until
    # killed. nohup detaches it from this short-lived click script.
    nohup "$CAFFEINATE" -d -i >/dev/null 2>&1 &
    echo $! > "$PIDFILE"
  fi
fi

awake || rm -f "$PIDFILE" 2>/dev/null   # drop a stale pidfile before painting
if awake; then
  sketchybar --set caffeine icon.color="$ACCENT"
else
  sketchybar --set caffeine icon.color="$MUTED"
fi
CAFFEINE
chmod +x "$HOME/.config/sketchybar/caffeine.sh"

# Stay-awake toggle: far-left item.
sketchybar --add item caffeine left \
  --set caffeine icon=$'\xef\x83\xb4' icon.font="JetBrainsMono Nerd Font:Bold:15.0" \
    icon.color="$MUTED" label.drawing=off padding_left=6 padding_right=6 \
    click_script="$HOME/.config/sketchybar/caffeine.sh toggle" \
    script="$HOME/.config/sketchybar/caffeine.sh" \
  --subscribe caffeine system_woke

# Pin the reversed workspace order (caffeine sits alone on the left), then paint
# initial state: the trigger runs every space handler (highlight + icons);
# --update runs the caffeine script.
sketchybar --reorder $order
sketchybar --trigger aerospace_workspace_change FOCUSED_WORKSPACE="$("$AEROSPACE" list-workspaces --focused 2>/dev/null)"
sketchybar --update
