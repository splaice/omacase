# omacase Ghostty config. Theme is swapped by `omacase theme` via the
# config-file include below (symlinked to themes/<name>/ghostty).
font-family = "JetBrainsMono Nerd Font"
font-size = 14
font-thicken = true

window-padding-x = 10
window-padding-y = 10
window-decoration = false
macos-titlebar-style = hidden
background-opacity = 0.97
mouse-hide-while-typing = true
copy-on-select = clipboard

# Theme is managed by omacase (symlink → ~/.config/ghostty/theme).
# Must be absolute: `config` is symlinked into the repo, so a relative
# path would resolve against the repo dir, not ~/.config/ghostty.
config-file = ~/.config/ghostty/theme
